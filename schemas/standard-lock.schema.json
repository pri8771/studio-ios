{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://studio.local/schemas/standard-lock.schema.json",
  "title": "Studio and Domain Standard Lock",
  "type": "object",
  "required": ["schemaVersion", "productId", "standards", "lastChecked"],
  "properties": {
    "schemaVersion": {"const": 1},
    "productId": {"type": "string", "pattern": "^PROD-"},
    "standards": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "repository", "version", "commit"],
        "properties": {
          "id": {"type": "string"},
          "repository": {"type": "string"},
          "version": {"type": "string"},
          "commit": {"type": "string", "minLength": 7},
          "overrides": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "lastChecked": {"type": "string", "format": "date"}
  },
  "additionalProperties": false
}
